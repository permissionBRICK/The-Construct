[Unit]
Description=The Construct Environment
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/construct/repo
EnvironmentFile=/etc/construct/config.env
EnvironmentFile=-/opt/construct/runtime/generated.env
ExecStartPre=/opt/construct/repo/bin/generate-runtime-config.sh
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
