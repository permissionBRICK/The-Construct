{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "The Construct Project Profile",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string",
            "minLength": 1
          },
          "directory": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "sdks": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        ]
      }
    },
    "mcp": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "comment": "Legacy enum: selects a docker-compose MCP container profile.",
            "type": "string",
            "enum": ["filesystem", "browser", "github"]
          },
          {
            "comment": "stdio (e.g. npx) MCP server written into each agent's config.",
            "type": "object",
            "required": ["name", "command"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "enum": ["stdio"] },
              "command": { "type": "string", "minLength": 1 },
              "args": { "type": "array", "items": { "type": "string" } },
              "env": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          },
          {
            "comment": "http MCP server written into each agent's config.",
            "type": "object",
            "required": ["name", "url"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "enum": ["http"] },
              "url": { "type": "string", "minLength": 1 },
              "headers": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "bearerTokenEnvVar": { "type": "string", "minLength": 1 }
            }
          }
        ]
      }
    },
    "hostPackages": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tests": {
      "type": "object"
    }
  }
}
