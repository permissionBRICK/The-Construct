{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "The Construct Project Profile",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string",
            "minLength": 1
          },
          "directory": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "sdks": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        ]
      }
    },
    "mcp": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["filesystem", "browser", "github"]
      }
    },
    "hostPackages": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tests": {
      "type": "object"
    }
  }
}
