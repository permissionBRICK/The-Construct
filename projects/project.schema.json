{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "The Construct Project Profile",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string",
            "minLength": 1
          },
          "directory": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "sdks": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        ]
      }
    },
    "mcp": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "comment": "stdio (e.g. npx) MCP server written into each agent's config.",
            "type": "object",
            "required": ["name", "command"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "enum": ["stdio"] },
              "command": { "type": "string", "minLength": 1 },
              "args": { "type": "array", "items": { "type": "string" } },
              "env": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "agents": {
                "comment": "Optional: only configure this server into these agents (default: all).",
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "enum": ["claude", "claude-code", "codex", "opencode"] }
              },
              "enabled": {
                "comment": "Optional: set false to add the server flagged disabled, toggleable in the agent UI (default true; Claude has no disable flag so it is omitted there).",
                "type": "boolean"
              }
            }
          },
          {
            "comment": "http MCP server written into each agent's config.",
            "type": "object",
            "required": ["name", "url"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "enum": ["http"] },
              "url": { "type": "string", "minLength": 1 },
              "headers": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "bearerTokenEnvVar": { "type": "string", "minLength": 1 },
              "agents": {
                "comment": "Optional: only configure this server into these agents (default: all).",
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "enum": ["claude", "claude-code", "codex", "opencode"] }
              },
              "enabled": {
                "comment": "Optional: set false to add the server flagged disabled, toggleable in the agent UI (default true; Claude has no disable flag so it is omitted there).",
                "type": "boolean"
              }
            }
          }
        ]
      }
    },
    "hostPackages": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "provisionCommands": {
      "comment": "Custom bash commands run, in array order, on EVERY provision -- AFTER this profile's repos are cloned and the SDKs installed. The working directory is this profile's first repo checkout (WORKSPACE_ROOT/<dir>), or WORKSPACE_ROOT when the profile declares no repo. Across multiple selected profiles they run in profile order. Run as root; must be idempotent. A failing command is logged but does not abort provisioning or the remaining commands.",
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tests": {
      "type": "object"
    }
  }
}
