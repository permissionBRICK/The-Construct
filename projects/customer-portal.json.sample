{
  "name": "customer-portal",
  "repos": [
    {
      "url": "git@github.com:YOUR_ORG/customer-portal.git",
      "directory": "customer-portal"
    },
    {
      "url": "git@github.com:YOUR_ORG/customer-portal-api.git",
      "directory": "customer-portal-api"
    }
  ],
  "sdks": {
    "node": ["22"],
    "python": ["3.12"]
  },
  "mcp": [
    {
      "name": "context7",
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": { "DEFAULT_MINIMUM_TOKENS": "5000" }
    },
    {
      "name": "sentry",
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp",
      "headers": { "Authorization": "Bearer YOUR_TOKEN" },
      "bearerTokenEnvVar": "SENTRY_MCP_TOKEN",
      "agents": ["claude-code", "opencode"]
    },
    {
      "name": "playwright",
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "agents": ["codex"],
      "enabled": false
    }
  ],
  "hostPackages": [],
  "provisionCommands": [
    "npm ci",
    "cp -n .env.example .env || true"
  ],
  "tests": {
    "web": {
      "runner": "playwright",
      "command": "npm test"
    }
  }
}
