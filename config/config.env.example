AGENT_NAME=agent-vm-01
PROJECTS=default
AGENT_HOME=/opt/construct
WORKSPACE_ROOT=/root/repos
SSH_USER=agent
ALLOW_HOST_PACKAGES=false
AI_TOOLS=opencode,claude-code,codex
OPENCODE_HOST=0.0.0.0
OPENCODE_PORT=4096
CODEX_HOST=0.0.0.0
CODEX_PORT=4500
CODEX_TOKEN_FILE=/etc/construct/codex-app-server.token

# The template ships with a minimal local runtime in agent-runtime/.
# Replace this with a registry image once the construct image exists.
AGENT_IMAGE=construct-local:latest
MCP_FILESYSTEM_IMAGE=ghcr.io/YOUR_ORG/mcp-filesystem:latest
MCP_GITHUB_IMAGE=ghcr.io/YOUR_ORG/mcp-github:latest
