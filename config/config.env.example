AGENT_NAME=agent-vm-01
PROJECTS=default
AGENT_HOME=/opt/construct
WORKSPACE_ROOT=/root/repos
SSH_USER=agent
ALLOW_HOST_PACKAGES=false
AI_TOOLS=opencode,claude-code,codex
OPENCODE_HOST=0.0.0.0
OPENCODE_PORT=4096
CODEX_HOST=0.0.0.0
CODEX_PORT=4500
CODEX_TOKEN_FILE=/etc/construct/codex-app-server.token

# VSCODE_SERVER: always install the VS Code CLI ("VS Code Server") so VS Code
# Remote-SSH works out of the box (set false to skip).
# VSCODE_SERVE_WEB: autostart `code serve-web` -- browser-based VS Code over HTTP,
# gated by a connection token (no account sign-in). Bound to
# VSCODE_SERVE_WEB_HOST:VSCODE_SERVE_WEB_PORT; reachable at
# http://<host>:<port>/?tkn=<token>. The token is generated into
# VSCODE_SERVE_WEB_TOKEN_FILE.
# VSCODE_TUNNEL: opt in to also autostart a `code tunnel`, reachable from
# vscode.dev with no inbound port. First-time setup needs a one-time browser
# sign-in (the provisioner pauses for it). Once registered, re-provisions keep
# the tunnel autostarting even with this set back to false.
# VSCODE_TUNNEL_NAME: the vscode.dev/tunnel/<name> identifier; blank = derived
# from the hostname.
VSCODE_SERVER=true
VSCODE_SERVE_WEB=true
VSCODE_SERVE_WEB_HOST=0.0.0.0
VSCODE_SERVE_WEB_PORT=8000
VSCODE_SERVE_WEB_TOKEN_FILE=/etc/construct/vscode-serve-web.token
VSCODE_TUNNEL=false
VSCODE_TUNNEL_NAME=

# The template ships with a minimal local runtime in agent-runtime/.
# Replace this with a registry image once the construct image exists.
AGENT_IMAGE=construct-local:latest
MCP_FILESYSTEM_IMAGE=ghcr.io/YOUR_ORG/mcp-filesystem:latest
MCP_GITHUB_IMAGE=ghcr.io/YOUR_ORG/mcp-github:latest
